# OpenClaw Gateway Configuration
# Copy this file to .env.local and update with your gateway details

# Gateway URL (HTTP format - will be auto-converted to WebSocket)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Gateway authentication token
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

OPENCLAW_GATEWAY_ORIGIN=http://localhost:3000

# Server port (optional, defaults to 3000)
# PORT=3000

# Node environment (optional, defaults to development)
# NODE_ENV=development

# Debug Gateway Events (optional, set to 'true' to enable detailed event logging)
# DEBUG_GATEWAY_EVENTS=false
